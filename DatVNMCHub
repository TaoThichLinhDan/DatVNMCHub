task.spawn(function()
    while task.wait() do
        if getgenv().DatVNMC_Config.AutoFarm and not getgenv().DatVNMC_Config.AutoMastery then
            pcall(function()
                local TargetMob = nil
                for _, v in pairs(game.Workspace.Enemies:GetChildren()) do
                    if v:FindFirstChild("Humanoid") and v.Humanoid.Health > 0 then
                        TargetMob = v
                        break
                    end
                end
                if TargetMob and LP.Character and LP.Character:FindFirstChild("HumanoidRootPart") then
                    if getgenv().DatVNMC_Config.BringMob then
                        for _, mob in pairs(game.Workspace.Enemies:GetChildren()) do
                            if mob.Name == TargetMob.Name and mob:FindFirstChild("HumanoidRootPart") then
                                mob.HumanoidRootPart.CFrame = TargetMob.HumanoidRootPart.CFrame
                                mob.HumanoidRootPart.CanCollide = false
                            end
                        end
                    end
                    ForceEquipWeapon(getgenv().DatVNMC_Config.SelectWeapon)
                    LP.Character.HumanoidRootPart.CFrame = TargetMob.HumanoidRootPart.CFrame * CFrame.new(0, 5, 0)
                    
                    local Tool = LP.Character:FindFirstChildOfClass("Tool")
                    if Tool and getgenv().DatVNMC_Config.FastAttack then 
                        Tool:Activate()
                        if getgenv().DatVNMC_Config.SelectWeapon == "Trái Blox" then
                            game:GetService("VirtualUser"):CaptureController()
                            game:GetService("VirtualUser"):Button1Down(Vector2.new(1280, 720))
                        end
                    end
                end
            end)
        end
    end
end)

