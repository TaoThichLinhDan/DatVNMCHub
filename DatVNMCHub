-- Hàm tự động dùng kỹ năng khi farm mastery (Đã sửa lỗi thiếu hàm)
local function UseSkills()
    pcall(function()
        local VirtualInputManager = game:GetService("VirtualInputManager")
        local Skills = {"Z", "X", "C", "V"}
        for _, skill in pairs(Skills) do
            VirtualInputManager:SendKeyEvent(true, Enum.KeyCode[skill], false, game)
            task.wait(0.1)
            VirtualInputManager:SendKeyEvent(false, Enum.KeyCode[skill], false, game)
        end
    end)
end

-- Hàm tự động lấy vũ khí
local function ForceEquipWeapon(WeaponName)
    pcall(function()
        if LP.Character then
            local CurrentTool = LP.Character:FindFirstChildOfClass("Tool")
            if CurrentTool then
                if WeaponName == "Melee" and (CurrentTool:FindFirstChild("Combat") or CurrentTool:FindFirstChild("Melee") or CurrentTool.ToolTip == "Melee") then return end
                if WeaponName == "Sword" and (CurrentTool.ToolTip == "Sword") then return end
                if WeaponName == "Trái Blox" and (CurrentTool.ToolTip == "Blox Fruit") then return end
                if WeaponName == "Gun" and (CurrentTool.ToolTip == "Gun") then return end
                CurrentTool.Parent = LP.Backpack
            end
            for _, v in pairs(LP.Backpack:GetChildren()) do
                if v:IsA("Tool") then
                    if WeaponName == "Melee" and (v:FindFirstChild("Combat") or v:FindFirstChild("Melee") or v.ToolTip == "Melee") then
                        LP.Character.Humanoid:EquipTool(v)
                        break
                    elseif WeaponName == "Sword" and (v.ToolTip == "Sword") then
                        LP.Character.Humanoid:EquipTool(v)
                        break
                    elseif WeaponName == "Trái Blox" and (v.ToolTip == "Blox Fruit") then
                        LP.Character.Humanoid:EquipTool(v)
                        break
                    elseif WeaponName == "Gun" and (v.ToolTip == "Gun") then
                        LP.Character.Humanoid:EquipTool(v)
                        break
                    end
                end
            end
        end
    end)
end

